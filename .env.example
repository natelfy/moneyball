# Copiez ce fichier en `.env` et ajustez les valeurs.
# `.env` est ignoré par git (voir .gitignore) : n'y mettez jamais de vrais
# secrets dans le dépôt. docker-compose charge automatiquement `.env`.

# --- MinIO (Datalake S3 / couche Bronze) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me

# --- PostgreSQL (Data Warehouse / couche Silver) ---
POSTGRES_USER=mlops
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scouting_db

# --- Accès applicatif S3 (doivent correspondre aux MINIO_ROOT_* ci-dessus) ---
S3_ACCESS_KEY=admin
S3_SECRET_KEY=change-me
S3_BUCKET=bronze-amateur-stats
S3_MODEL_BUCKET=ml-models

# --- Paramètres d'exécution des jobs ---
TARGET_URL=
FILE_NAME=
